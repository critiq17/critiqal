		"jsdom": "^29.0.2",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.4"
	},
	"dependencies": {
		"@sveltejs/adapter-node": "^5.5.4"
